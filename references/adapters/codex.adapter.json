{
  "schema_version": "1",
  "protocol_version": "1",
  "adapter_version": "1",
  "provider": "codex",
  "worker_types": ["codex-thread"],
  "capabilities": [
    "api",
    "background-worker",
    "browser",
    "code-edit",
    "git",
    "heartbeat",
    "shell",
    "sql"
  ],
  "components": {
    "worker": {
      "transport": "tool",
      "create": {
        "target": "create_thread",
        "input_fields": ["title", "prompt"],
        "worker_id_path": "$.threadId",
        "status_path": "$.status",
        "timeout_seconds": 120
      },
      "inspect": {
        "target": "read_thread",
        "input_fields": ["worker_id"],
        "worker_id_path": "$.threadId",
        "status_path": "$.status",
        "timeout_seconds": 30
      },
      "cancel": {
        "target": "set_thread_archived",
        "input_fields": ["worker_id"],
        "worker_id_path": "$.threadId",
        "status_path": "$.status",
        "timeout_seconds": 30
      },
      "supports_background": true
    },
    "model": {
      "default_model": "gpt-5.6-sol",
      "fallback_models": []
    },
    "monitor": {
      "modes": ["heartbeat", "manual"],
      "supports_lease_renewal": true
    },
    "evidence": {
      "artifact_kinds": [
        "api",
        "browser",
        "command",
        "id",
        "log",
        "release_path",
        "screenshot",
        "sql",
        "upgrade_path"
      ],
      "sources": ["automation", "codex-browser", "git", "shell"]
    }
  },
  "models": [
    {
      "id": "gpt-5.6-sol",
      "aliases": ["5.6 sol"],
      "quality": "frontier",
      "latency_class": "normal",
      "cost_class": "balanced",
      "reasoning_profiles": {
        "fast": "low",
        "standard": "medium",
        "deep": "high",
        "critical": "xhigh"
      }
    }
  ]
}
