{
  "schema_version": "1",
  "protocol_version": "1",
  "adapter_version": "1",
  "provider": "external-cli",
  "worker_types": ["agent-thread"],
  "capabilities": [
    "api",
    "background-worker",
    "code-edit",
    "git",
    "shell",
    "sql"
  ],
  "components": {
    "worker": {
      "transport": "command",
      "create": {
        "target": "agent start --json",
        "input_fields": ["title", "prompt"],
        "worker_id_path": "$.worker_id",
        "status_path": "$.status",
        "timeout_seconds": 120
      },
      "inspect": {
        "target": "agent status --json",
        "input_fields": ["worker_id"],
        "worker_id_path": "$.worker_id",
        "status_path": "$.status",
        "timeout_seconds": 30
      },
      "cancel": {
        "target": "agent cancel --json",
        "input_fields": ["worker_id"],
        "worker_id_path": "$.worker_id",
        "status_path": "$.status",
        "timeout_seconds": 30
      },
      "supports_background": true
    },
    "model": {
      "default_model": "external-frontier",
      "fallback_models": []
    },
    "monitor": {
      "modes": ["poll", "manual"],
      "supports_lease_renewal": false
    },
    "evidence": {
      "artifact_kinds": ["api", "command", "id", "log", "sql"],
      "sources": ["external-agent", "git", "shell"]
    }
  },
  "models": [
    {
      "id": "external-frontier",
      "aliases": [],
      "quality": "frontier",
      "latency_class": "normal",
      "cost_class": "balanced",
      "reasoning_profiles": {
        "fast": "quick",
        "standard": "normal",
        "deep": "deliberate",
        "critical": "maximum"
      }
    }
  ]
}
