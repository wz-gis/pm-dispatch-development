{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pm-dispatch.local/evidence.schema.json",
  "title": "PM Dispatch Evidence",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "task_id", "generated_at", "verification", "artifacts", "runs", "blockers", "conclusion"],
  "properties": {
    "schema_version": {"type": "string", "enum": ["2"]},
    "task_id": {"type": "string", "pattern": "^(BUG|SPEC|ONBOARD|RELEASE|ENV|CHORE)-[0-9]{3}$"},
    "generated_at": {"type": "string", "format": "date-time"},
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["changed_surface", "original_user_path", "runtime_shape", "test_data", "levels", "existing_data_regression", "uncovered_items"],
      "properties": {
        "changed_surface": {"type": "array", "items": {"type": "string"}},
        "original_user_path": {"type": "string"},
        "runtime_shape": {"type": "string", "enum": ["dev", "jar", "release", "mock", "real"]},
        "test_data": {"type": "array", "items": {"type": "string"}},
        "levels": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "L0": {"$ref": "#/$defs/level"},
            "L1": {"$ref": "#/$defs/level"},
            "L2": {"$ref": "#/$defs/level"},
            "L3": {"$ref": "#/$defs/level"},
            "L4": {"$ref": "#/$defs/level"}
          }
        },
        "existing_data_regression": {"type": "string"},
        "uncovered_items": {"type": "array", "items": {"type": "string"}}
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commands", "commits", "files_changed", "api", "sql", "browser", "screenshots", "logs", "ids", "upgrade_path", "release_path"],
      "properties": {
        "commands": {"type": "array", "items": {"$ref": "#/$defs/command_artifact"}},
        "commits": {"type": "array", "items": {"type": "string"}},
        "files_changed": {"type": "array", "items": {"type": "string"}},
        "api": {"type": "array", "items": {"$ref": "#/$defs/artifact"}},
        "sql": {"type": "array", "items": {"$ref": "#/$defs/artifact"}},
        "browser": {"type": "array", "items": {"$ref": "#/$defs/artifact"}},
        "screenshots": {"type": "array", "items": {"$ref": "#/$defs/artifact"}},
        "logs": {"type": "array", "items": {"$ref": "#/$defs/artifact"}},
        "ids": {"type": "array", "items": {"$ref": "#/$defs/artifact"}},
        "upgrade_path": {"type": "array", "items": {"$ref": "#/$defs/artifact"}},
        "release_path": {"type": "array", "items": {"$ref": "#/$defs/artifact"}}
      }
    },
    "runs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["run_id", "attempt_id", "worker_type", "worker_name", "worker_label", "worker_id", "status"],
        "properties": {
          "run_id": {"type": "string"},
          "attempt_id": {"type": "string"},
          "worker_type": {"type": "string"},
          "worker_name": {"type": "string"},
          "worker_label": {"type": "string"},
          "worker_id": {"type": ["string", "null"]},
          "commit": {"type": ["string", "null"]},
          "status": {"type": "string"}
        }
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "type", "status", "description"],
        "properties": {
          "id": {"type": "string"},
          "type": {"type": "string", "enum": ["environment", "contract", "thread", "pm", "dependency", "resource"]},
          "status": {"type": "string", "enum": ["open", "resolved", "accepted"]},
          "description": {"type": "string"},
          "resolution": {"type": ["string", "null"]}
        }
      }
    },
    "conclusion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "evidence_level", "mock_based", "real_chain_verified", "accepted_fallback"],
      "properties": {
        "status": {"type": "string", "enum": ["VERIFIED", "L0_VERIFIED_MOCK", "L1_VERIFIED_MOCK", "L2_VERIFIED_MOCK", "L3_VERIFIED_MOCK", "L4_VERIFIED_MOCK", "PARTIAL_VERIFIED", "ENV_BLOCKED", "CONTRACT_BLOCKED", "THREAD_BLOCKED", "PM_BLOCKED"]},
        "evidence_level": {"type": "string", "enum": ["NONE", "L0", "L1", "L2", "L3", "L4"]},
        "mock_based": {"type": "boolean"},
        "real_chain_verified": {"type": "boolean"},
        "accepted_fallback": {"type": ["string", "null"]},
        "notes": {"type": ["string", "null"]}
      }
    }
  },
  "$defs": {
    "level": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "summary"],
      "properties": {
        "status": {"type": "string", "enum": ["not_required", "pending", "pass", "pass_mock", "fail", "blocked"]},
        "summary": {"type": "string"},
        "evidence_refs": {"type": "array", "items": {"type": "string"}},
        "commands": {"type": "array", "items": {"type": "string"}}
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_id", "kind", "source", "subject", "result", "captured_at", "evidence_ref"],
      "properties": {
        "artifact_id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
        "kind": {"type": "string", "enum": ["api", "sql", "browser", "screenshot", "log", "id", "upgrade_path", "release_path"]},
        "source": {"type": "string", "minLength": 1},
        "subject": {"type": "string", "minLength": 1},
        "result": {"type": "string", "enum": ["pass", "fail", "info"]},
        "captured_at": {"type": "string", "format": "date-time"},
        "evidence_ref": {"type": "string", "minLength": 1},
        "status_code": {"type": ["integer", "null"]},
        "digest": {"type": ["string", "null"]}
      }
    },
    "command_artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_id", "kind", "source", "subject", "result", "captured_at", "evidence_ref", "command", "exit_code"],
      "properties": {
        "artifact_id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
        "kind": {"type": "string", "enum": ["command"]},
        "source": {"type": "string", "minLength": 1},
        "subject": {"type": "string", "minLength": 1},
        "result": {"type": "string", "enum": ["pass", "fail", "info"]},
        "captured_at": {"type": "string", "format": "date-time"},
        "evidence_ref": {"type": "string", "minLength": 1},
        "command": {"type": "string", "minLength": 1},
        "exit_code": {"type": "integer"}
      }
    }
  }
}
